{
  "manifest_version": 3,
  "name": "Possum Fetcher",
  "version": "1.0.1",
  "description": "Flight route decoder companion for possumfix.com",
  "permissions": [
    "storage",
    "cookies"
  ],
  "host_permissions": [
    "https://www.flightaware.com/*",
    "https://flightaware.com/*",
    "http://www.airnav.com/*",
    "http://airnav.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://possumfix.com/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}